{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_PAT}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "./documentation"]
    },
    "simpler-grants-context": {
      "command": "npx",
      "args": ["-y", "tsx", "./mcp-server/src/index.ts"]
    }
  }
}
